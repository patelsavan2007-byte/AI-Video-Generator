# ─────────────────────────────────────────────────────────────
#  VisionForge 2.0 — Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# --- Infrastructure ---
POSTGRES_URL=postgresql+asyncpg://vf:secret@postgres:5432/visionforge
POSTGRES_USER=vf
POSTGRES_PASSWORD=secret
POSTGRES_DB=visionforge
REDIS_URL=redis://redis:6379/0

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret-key-before-use
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Storage ---
MEDIA_ROOT=/media

# --- Worker / Model ---
# Absolute host path to your Wan2.x weights directory
WAN2_MODEL_PATH=/models/wan2
MAX_CONCURRENT_JOBS=2

# --- Debug mode ---
# Set to true to skip GPU/model loading entirely.
# The worker returns a dummy MP4 and simulates progress updates.
# Perfect for testing the full UI/API flow without a GPU.
DEBUG_MODE=false

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
